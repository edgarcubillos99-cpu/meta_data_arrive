# ─── Servidor ───────────────────────────────────────────────
PORT=3000
APP_BASE_URL=http://localhost:3000

# ─── Meta / WhatsApp ────────────────────────────────────────
# Token que Meta enviará al verificar el webhook (GET /webhooks/meta)
META_VERIFY_TOKEN=your_verify_token_here
# Secreto de la app para validar la firma x-hub-signature-256
META_APP_SECRET=your_app_secret_here

# WhatsApp Cloud API (envío de mensajes — pregunta antes de enriquecer)
# IDs en Meta for Developers > WhatsApp > API setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_TOKEN=
# Opcional, por defecto v21.0
# WHATSAPP_GRAPH_API_VERSION=v21.0

# Mensaje automático antes del enriquecimiento (clientes actuales vs potenciales)
# SERVICE_INQUIRY_MESSAGE=Tu texto personalizado aquí
# SERVICE_INQUIRY_SEND_ONCE=true

# Messenger + Instagram Direct (misma app Meta; Send API de la página)
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
# Solo si el ID de página para Instagram es distinto al de Facebook
# INSTAGRAM_PAGE_ID=
# META_GRAPH_API_VERSION=v21.0

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URI=amqp://user:password@localhost:5672

# ─── Ubersmith CRM ──────────────────────────────────────────
UBERSMITH_API_URL=https://your-ubersmith-instance.example.com
