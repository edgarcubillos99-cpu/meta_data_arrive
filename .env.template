# ─── Servidor ───────────────────────────────────────────────
PORT=3000
APP_BASE_URL=http://localhost:3000

# ─── Meta / WhatsApp ────────────────────────────────────────
# Token que Meta enviará al verificar el webhook (GET /webhooks/meta)
META_VERIFY_TOKEN=your_verify_token_here
# Secreto de la app para validar la firma x-hub-signature-256
META_APP_SECRET=your_app_secret_here

# WhatsApp Cloud API (Meta for Developers > WhatsApp > API setup)
WHATSAPP_PHONE_NUMBER_ID=
# Token de la app: resuelve URL de medios en el normalizador; mismo token para enviar mensajes (sendText).
WHATSAPP_GRAPH_API_TOKEN=
# Opcional, por defecto v21.0
# WHATSAPP_GRAPH_API_VERSION=v21.0

# Messenger + Instagram Direct — Send API (envío desde tu backend; la entrada sigue siendo el webhook)
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
# Solo si el ID de página de Instagram difiere del de Facebook
# INSTAGRAM_PAGE_ID=
# META_GRAPH_API_VERSION=v21.0

# ─── RabbitMQ
RABBITMQ_URI=amqp://user:password@localhost:5672
# Opcional: reconexión automática si cae el broker (segundos entre intentos; por defecto 5)
# RABBITMQ_RECONNECT_SECONDS=5
# Intervalo de heartbeat del cliente hacia RabbitMQ (por defecto 30; más alto = menos sensible a microcortes)
# RABBITMQ_HEARTBEAT_INTERVAL_SECONDS=30

# ─── ClamAV daemon TCP (docker-compose: servicio clamav:3310) ─
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310
